rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Привычки — доступ только владельцу + валидация полей
    match /tasks/{taskId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.keys().hasAll(['id', 'title', 'userId'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 600));
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 600));
    }

    // Цели — доступ только владельцу + валидация полей
    match /goals/{goalId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.keys().hasAll(['id', 'title', 'userId'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 600));
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && (!('description' in request.resource.data) || (request.resource.data.description is string && request.resource.data.description.size() <= 600));
    }

    // Пользовательские данные (notes, backgroundId) — доступ только владельцу + валидация
    match /users/{userId} {
      allow read: if request.auth != null
                  && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() <= 10000))
                   && (!('backgroundId' in request.resource.data) || (request.resource.data.backgroundId is string && request.resource.data.backgroundId.size() <= 50));
    }
  }
}
